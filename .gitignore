users.json
visitor_emails.json
*.pkl
*.h5
*.keras
saved_model/
models/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini
